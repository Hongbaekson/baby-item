{
  "name": "euni-baby-items",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "serve:dist": "node ./scripts/serve-dist.mjs",
    "data:check": "node ./scripts/check-app-data.mjs",
    "price:check-readiness": "node ./scripts/check-price-sync-readiness.mjs",
    "data:extract": "node ./scripts/extract-notion-items.mjs",
    "data:normalize": "node ./scripts/normalize-items.mjs && node ./scripts/build-canonical-items.mjs && node ./scripts/normalize-links.mjs && node ./scripts/apply-data-quality.mjs && node ./scripts/build-app-data.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2"
  }
}
